{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to Eden GDB Stub",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/${workspaceFolderBasename}.elf",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "${env:DEVKITPRO}/devkitA64/bin/aarch64-none-elf-gdb",
            "miDebuggerServerAddress": "192.168.0.236:6543",

            "stopAtConnect": true,
            "launchCompleteCommand": "None",

            "setupCommands": [
                { "text": "set pagination off" },
                { "text": "set breakpoint pending on" }
            ],

            // "logging": {
            //     "engineLogging": true,
            //     "trace": true,
            //     "traceResponse": true
            // }
        }
    ]
}